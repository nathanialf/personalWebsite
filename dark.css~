html,body
{
  margin: 0;
  background-color: #E5E5E5;
  font-family: 'Roboto', sans-serif;
}

#header
{
  top: 0;
  width: 100%;
  position: fixed;
  font-size: 20px;
  padding: 12px;
  color: #FFFFFF;
  background-color: #66BB6A;
  box-shadow :0px 2px 5px rgba(1, 1, 1, 0.5);
}

.item
{
  background-color: #FFFFFF;
  border-radius: 2px;
  font-size: 18px;
  margin: 20px;
  padding: 10px;
  box-shadow :0px 2px 5px rgba(0, 0, 0, 0.5);
}

.subitem
{
  font-size: 12px;
  padding: 7px 0px 10px 0px;
}

.link
{
  color: #000000;
  background-color: #DDDDDD;
  box-shadow :0px 2px 5px rgba(0, 0, 0, 0);

  -webkit-transition: background-color 200ms, box-shadow 200ms, color 200ms;
  -moz-transition: background-color 200ms, box-shadow 200ms, color 200ms;
  -o-transition: background-color 200ms, box-shadow 200ms, color 200ms;
  -ms-transition: background-color 200ms, box-shadow 200ms, color 200ms;

  border-radius:2px;
  padding: 5px;
}

.link:hover
{
  color: #FFFFFF;
  background-color: #66BB6A;
  box-shadow :0px 2px 5px rgba(0, 0, 0, 0.5);

  -webkit-transition: background-color 200ms, box-shadow 200ms, color 200ms;
  -moz-transition: background-color 200ms, box-shadow 200ms, color 200ms;
  -o-transition: background-color 200ms, box-shadow 200ms, color 200ms;
  -ms-transition: background-color 200ms, box-shadow 200ms, color 200ms;

  border-radius:2px;
  padding: 5px;
}

a:link {color: #000000; text-decoration: none; }